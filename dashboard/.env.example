# URL base da API de busca (Fase 2 - Fastify).
# Em desenvolvimento você pode deixar vazio para usar o proxy do Vite (/api),
# ou apontar direto para a API local.
VITE_API_URL=http://localhost:3333

# Quando "true", se a API estiver indisponível o dashboard carrega dados de
# exemplo (mock) para você visualizar o layout sem o backend no ar.
# Em produção, deixe "false".
VITE_USE_MOCK_FALLBACK=true
