# Local SQLite database. Prisma resolves this path from the prisma/ folder.
DATABASE_URL="file:./dev.db"

# Generate a new value for each environment:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET="replace-with-a-long-random-secret"

# Optional: restrict API CORS. Leave "*" while using the Vite dashboard locally.
CORS_ORIGIN="*"

# Optional Google Custom Search integration. The free RSS provider works without keys.
GOOGLE_API_KEY=""
GOOGLE_CSE_ID=""
